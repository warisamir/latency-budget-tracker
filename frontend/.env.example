# API Configuration
# Replace with your Render backend URL
VITE_API_URL=https://your-service.onrender.com/api/v1

# API Credentials
# Must match SECURITY_USER and SECURITY_PASSWORD on the Render backend
VITE_API_USER=admin
VITE_API_PASSWORD=your-secure-password

# Local development (proxy configured in vite.config.ts)
# VITE_API_URL=http://localhost:8080/api/v1
# VITE_API_USER=admin
# VITE_API_PASSWORD=admin123
