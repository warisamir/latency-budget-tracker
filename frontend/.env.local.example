# Local Development Environment Variables
# Copy this file to .env.local and update values as needed

# Backend API Configuration (local)
VITE_API_URL=http://localhost:8080/api/v1

# API Credentials (same as backend dev defaults)
VITE_API_USER=admin
VITE_API_PASSWORD=admin123

# Note: With Vite's dev proxy configured in vite.config.ts,
# requests to /api will be proxied to http://localhost:8080
# So VITE_API_URL can also be /api/v1 (relative path)
