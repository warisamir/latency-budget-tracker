# Latency Budget Tracker — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# PostgreSQL JDBC URL (format: jdbc:postgresql://host:port/database?sslmode=require)
DB_URL=jdbc:postgresql://localhost:5432/latencydb?sslmode=disable
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20
DB_DDL_AUTO=update

# ═══════════════════════════════════════════════════════════════════════════════
# CACHE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Basic Auth credentials for API endpoints
# IMPORTANT: Change these in production!
SECURITY_USER=admin
SECURITY_PASSWORD=changeme

# ═══════════════════════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins (no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ═══════════════════════════════════════════════════════════════════════════════
# OBSERVABILITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
TRACING_SAMPLE_RATE=0.1
OTEL_ENDPOINT=http://localhost:4317

# ═══════════════════════════════════════════════════════════════════════════════
# JVM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
JAVA_VERSION=21
JAVA_OPTS=-Xmx512m -Xms256m

# ═══════════════════════════════════════════════════════════════════════════════
# LATENCY BUDGET CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Budget thresholds (milliseconds)
LATENCY_BUDGET_AUTHENTICATION=20
LATENCY_BUDGET_VALIDATION=10
LATENCY_BUDGET_BUSINESS_LOGIC=50
LATENCY_BUDGET_CACHE_ACCESS=10
LATENCY_BUDGET_DATABASE_QUERY=40
LATENCY_BUDGET_RESPONSE_SERIALIZATION=5
LATENCY_BUDGET_TOTAL=135

# Alert configuration
LATENCY_ALERTING_COOLDOWN_MINUTES=5
LATENCY_ALERTING_DEDUPLICATION_WINDOW_MINUTES=10

# Regression detection
LATENCY_REGRESSION_CHECK_INTERVAL_MS=300000
